<Window x:Class="PebbleInjector.ConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PebbleInjector Console" Height="300" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="#121212"
        ResizeMode="CanResizeWithGrip">
    <Border BorderBrush="#FF489B5E" BorderThickness="1" CornerRadius="8">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="PebbleInjector Console" Foreground="White"
                       FontWeight="Bold" Margin="0,0,0,8"
                       MouseLeftButtonDown="DragWindow"/>
            <TextBox x:Name="ConsoleText" Grid.Row="1"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#121212" Foreground="#FFE0E0E0"
                     BorderThickness="0" FontFamily="Consolas"
                     Text="[Console] Ready."/>
        </Grid>
    </Border>
</Window>
